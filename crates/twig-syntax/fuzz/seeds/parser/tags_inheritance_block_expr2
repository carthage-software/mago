{% extends "base.twig" %}
--TEMPLATE(base.twig)--
{% block element -%}
    <div>
        {%- if item.children is defined %}
            {%- for item in item.children %}
                {{- block('element') -}}
            {% endfor %}
        {%- endif -%}
    </div>
{%- endblock %}